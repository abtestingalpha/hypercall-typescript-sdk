{
  "name": "@hypercall/sdk",
  "version": "0.0.0",
  "description": "TypeScript SDK for Hypercall",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/mod.js",
  "module": "./dist/mod.js",
  "types": "./dist/mod.d.ts",
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "import": "./dist/mod.js",
      "default": "./dist/mod.js"
    },
    "./api/info": {
      "types": "./dist/api/info/mod.d.ts",
      "import": "./dist/api/info/mod.js",
      "default": "./dist/api/info/mod.js"
    },
    "./api/exchange": {
      "types": "./dist/api/exchange/mod.d.ts",
      "import": "./dist/api/exchange/mod.js",
      "default": "./dist/api/exchange/mod.js"
    },
    "./signing": {
      "types": "./dist/signing/mod.d.ts",
      "import": "./dist/signing/mod.js",
      "default": "./dist/signing/mod.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "example": "tsx --tsconfig tsconfig.examples.json",
    "test": "pnpm build && node --test",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.examples.json --noEmit"
  },
  "dependencies": {
    "@valibot/valibot": "npm:valibot@1.1.0"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "viem": "^2.43.1"
  },
  "packageManager": "pnpm@10.0.0"
}
